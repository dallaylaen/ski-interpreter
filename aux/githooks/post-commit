#!/bin/sh

set -ex

AUTOFILES="docs/build docs/man types"

modified() {
    LIST=$(git status --porcelain -- "$@" | grep '^ *[AMD?]' | awk '{print $2}')
    echo $LIST
}

# We must postpone docs generation until after the commit hash is known,
# otherwise there will be revision spam and/or wrong links in the docs.
npm run tsdoc

CHANGED=$(modified $AUTOFILES)

if [ ! -z "$CHANGED" ]; then
    HOLD=$(modified src test site-src);
    if [ -z "$HOLD" ]; then
        # TODO some checking
        git commit $CHANGED -m "[auto] Update autogenerated $CHANGED" --no-verify
    else
        echo >&2 "[githook] Would commit ($CHANGED) if not for uncommitted ($HOLD)"
    fi
fi


